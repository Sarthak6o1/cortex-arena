# Cortex Arena is Ollama-first and works without API keys.
# For company-local and HIPAA-aligned evaluation, keep cloud providers disabled
# unless your security/legal team explicitly approves BYOK egress.

# Local Ollama server URL.
OLLAMA_BASE_URL=http://localhost:11434

# Optional bring-your-own-key providers. Leave blank unless you want cloud models.
HUGGINGFACE_API_KEY=
NVIDIA_API_KEY=

# Local SQLite database path.
DATABASE_PATH=data/arena.sqlite3
